{
    "name": "pkk/modular-report-engine",
    "description": "Modular report engine scaffold and test suite.",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^12.0",
        "dompdf/dompdf": "^3.1",
        "phpoffice/phpword": "^1.4",
        "inertiajs/inertia-laravel": "^2.0",
        "laravel/sanctum": "^4.0",
        "tightenco/ziggy": "^2.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24",
        "laravel/breeze": "^2.3",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.9",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "scripts": {
        "test": "phpunit -c phpunit.xml.dist"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
